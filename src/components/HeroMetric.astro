---
interface Props {
  metric: string;
  label: string;
}

const { metric, label } = Astro.props;
---

<div class="flex flex-col">
  <span class="text-3xl sm:text-4xl font-[var(--font-heading)] font-bold text-gradient leading-tight">
    {metric}
  </span>
  <span class="text-sm text-[var(--color-text-muted)] mt-1">
    {label}
  </span>
</div>
