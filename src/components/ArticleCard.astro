---
interface Props {
  slug: string;
  title: string;
  description: string;
  publishDate: Date;
  tags: string[];
}

const { slug, title, description, publishDate, tags } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/writing/${slug}`}
  class="group block glass-panel rounded-xl p-6 card-hover"
>
  <time
    datetime={publishDate.toISOString()}
    class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider"
  >
    {formattedDate}
  </time>

  <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mt-2 mb-2 group-hover:text-[var(--color-accent)] transition-colors duration-200">
    {title}
  </h3>

  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">{description}</p>

  <div class="flex flex-wrap gap-2">
    {tags.slice(0, 3).map((tag) => (
      <span class="text-xs px-2 py-1 rounded-md bg-[var(--color-bg-surface)] text-[var(--color-text-muted)]">
        {tag}
      </span>
    ))}
  </div>
</a>
