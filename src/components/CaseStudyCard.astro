---
import CategoryBadge from './CategoryBadge.astro';
import HeroMetric from './HeroMetric.astro';

interface Props {
  slug: string;
  title: string;
  subtitle: string;
  description: string;
  category: 'optimization' | 'architecture' | 'infrastructure' | 'vision';
  tags: string[];
  heroMetric?: string;
  heroMetricLabel?: string;
}

const { slug, title, subtitle, description, category, tags, heroMetric, heroMetricLabel } = Astro.props;
---

<a
  href={`/case-studies/${slug}`}
  class="group block glass-panel rounded-xl p-6 card-hover"
>
  <div class="flex items-start justify-between gap-4 mb-4">
    <CategoryBadge category={category} />
    {heroMetric && heroMetricLabel && (
      <HeroMetric metric={heroMetric} label={heroMetricLabel} />
    )}
  </div>

  <h3 class="text-xl font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--color-accent)] transition-colors duration-200">
    {title}
  </h3>
  <p class="text-sm text-[var(--color-text-muted)] mb-3">{subtitle}</p>
  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">{description}</p>

  <div class="flex flex-wrap gap-2">
    {tags.slice(0, 4).map((tag) => (
      <span class="text-xs px-2 py-1 rounded-md bg-[var(--color-bg-surface)] text-[var(--color-text-muted)]">
        {tag}
      </span>
    ))}
  </div>
</a>
