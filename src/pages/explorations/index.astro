---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const explorations = (await getCollection('explorations'))
  .filter((entry) => entry.data.status === 'published')
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout title="Explorations | Travis Carter" description="Concepts, experiments, and forward-looking ideas in AI orchestration, streaming systems, and developer tooling.">
  <section class="section-spacing px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
    <div class="max-w-3xl mb-12">
      <h1 class="mb-4">Explorations</h1>
      <p data-animate="fade" class="text-lg text-[var(--color-text-secondary)]">
        Ideas I'm actively thinking through. These are concepts and early-stage projects — not shipped work,
        but directions I'm heading.
      </p>
    </div>

    {explorations.length > 0 ? (
      <div class="grid grid-cols-1 gap-6">
        {explorations.map((entry, i) => (
          <a
            href={`/explorations/${entry.id}`}
            class="group block glass-panel rounded-xl p-6 card-hover"
            data-animate="slide-up"
            data-animate-delay={String(Math.min(i + 1, 4))}
          >
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full bg-[color-mix(in_srgb,var(--color-cat-vision)_15%,transparent)] text-[var(--color-cat-vision)]">
                Exploration
              </span>
            </div>
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--color-accent)] transition-colors duration-200">
              {entry.data.title}
            </h2>
            <p class="text-sm text-[var(--color-text-muted)] mb-3">{entry.data.subtitle}</p>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">{entry.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.slice(0, 4).map((tag) => (
                <span class="text-xs px-2 py-1 rounded-md bg-[var(--color-bg-surface)] text-[var(--color-text-muted)]">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-[var(--color-text-muted)] text-center py-12">
        Explorations coming soon.
      </p>
    )}
  </section>
</PageLayout>
